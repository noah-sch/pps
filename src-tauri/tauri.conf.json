{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PPS",
  "version": "0.1.0",
  "identifier": "com.pps.app",
  "build": {
    "frontendDist": "../front/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix front run dev",
    "beforeBuildCommand": "npm --prefix front run build"
  },
  "app": {
    "windows": [
      {
        "title": "PPS",
        "width": 1200,
        "height": 840,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "HealthcareFitness",
    "shortDescription": "Carnet d'entrainement",
    "longDescription": "PPS - un carnet d'entrainement structure autour de ta routine muscu. Enregistre tes seances, suis ton volume, tes records et ta regularité.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
